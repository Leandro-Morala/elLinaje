<HelpSheet@BoxLayout>:
    orientation: 'vertical'
    padding: '20dp'
    spacing: '15dp'
    canvas.before:
        Color:
            rgba: (0.95, 0.92, 0.85, 1) # Color hueso/pergamino
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [20,]
        Color:
            rgba: (0.3, 0.2, 0.1, 1) # Borde marrón
        Line:
            rounded_rectangle: (self.x, self.y, self.width, self.height, 20)
            width: 1.5

    # Encabezado
    Label:
        id: help_title
        text: "Título de Ayuda"
        font_size: '24sp'
        bold: True
        color: (0.2, 0.1, 0, 1)
        size_hint_y: None
        height: '50dp'
        halign: 'center'

    # Cuerpo (Texto extenso con Scroll)
    ScrollView:
        Label:
            id: help_body
            text: "Aquí va el texto descriptivo que explica el funcionamiento de la sección actual..."
            font_size: '16sp'
            color: (0.3, 0.2, 0.1, 1)
            text_size: self.width, None
            size_hint_y: None
            height: self.texture_size[1]
            halign: 'justify'
            padding: ('10dp', '10dp')

    # Pie con Botones de Navegación
    BoxLayout:
        size_hint_y: None
        height: '60dp'
        spacing: '10dp'
        
        BotonEstilizado:
            texto: "Atrás"
            color_fondo: (0.8, 0.8, 0.8, 1)
            on_release: root.prev_page()
            opacity: 1 if root.current_index > 0 else 0
            disabled: root.current_index == 0

        BotonEstilizado:
            id: btn_next
            texto: "Siguiente" if root.current_index < root.total_pages - 1 else "Entendido"
            color_fondo: (0.4, 0.6, 0.4, 1)
            on_release: root.next_page()
