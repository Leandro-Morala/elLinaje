<ManiScreen>:
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: 0.06, 0.06, 0.12, 1
            Rectangle:
                pos: self.pos
                size: self.size
        Label:
            text: "Redirigiendo..."
            color: 0.95, 0.78, 0.1, 1
            font_size: '16sp'
