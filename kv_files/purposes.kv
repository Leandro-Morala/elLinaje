<PurposesScreen>:
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: 0.06, 0.06, 0.12, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # --- TITULO ---
        BoxLayout:
            size_hint_y: None
            height: '50dp'
            canvas.before:
                Color:
                    rgba: 0.08, 0.08, 0.18, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 0.95, 0.78, 0.1, 0.7
                Line:
                    points: self.x, self.y, self.x + self.width, self.y
                    width: 1.5
            Label:
                text: "Metas"
                font_size: '20sp'
                bold: True
                color: 0.95, 0.78, 0.1, 1

        # --- BOTON NUEVA META ---
        BoxLayout:
            size_hint_y: None
            height: '52dp'
            padding: '10dp', '6dp'
            canvas.before:
                Color:
                    rgba: 0.07, 0.07, 0.15, 1
                Rectangle:
                    pos: self.pos
                    size: self.size

            BotonEstilizado:
                texto: "+ Nueva Meta"
                mostrar_icono: False
                color_fondo: (0.18, 0.45, 0.78, 1)
                on_release: root.nueva_meta()

        # --- LISTA DE METAS ---
        ScrollView:
            do_scroll_x: False
            size_hint_y: 1

            BoxLayout:
                id: metas_list
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: '10dp', '8dp'
                spacing: '6dp'

        # --- BOTON VOLVER ---
        BotonEstilizado:
            texto: "Volver al Principal"
            size_hint_y: None
            height: '52dp'
            mostrar_icono: False
            color_fondo: (0.3, 0.3, 0.3, 0.6)
            on_release:
                app.root.transition.direction = 'right'
                app.root.current = 'main'
