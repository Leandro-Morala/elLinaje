<VersesGameScreen>:
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: 0.06, 0.06, 0.12, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # --- TITULO ---
        BoxLayout:
            size_hint_y: None
            height: '50dp'
            canvas.before:
                Color:
                    rgba: 0.08, 0.08, 0.18, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 0.95, 0.78, 0.1, 0.7
                Line:
                    points: self.x, self.y, self.x + self.width, self.y
                    width: 1.5
            Label:
                text: "Desafio Biblico"
                font_size: '20sp'
                bold: True
                color: 0.95, 0.78, 0.1, 1

        # --- TEXTO DEL VERSICULO ---
        ScrollView:
            size_hint_y: None
            height: '150dp'
            do_scroll_x: False
            canvas.before:
                Color:
                    rgba: 0.1, 0.1, 0.22, 1
                RoundedRectangle:
                    pos: self.x + dp(8), self.y + dp(4)
                    size: self.width - dp(16), self.height - dp(8)
                    radius: [dp(10)]
                Color:
                    rgba: 0.95, 0.78, 0.1, 0.35
                Line:
                    rounded_rectangle: self.x + dp(9), self.y + dp(5), self.width - dp(18), self.height - dp(10), dp(9)
                    width: 1.2

            Label:
                text: root.verse_text
                font_size: '17sp'
                color: 0.95, 0.95, 0.88, 1
                halign: 'center'
                valign: 'middle'
                text_size: self.width - dp(24), None
                size_hint_y: None
                height: max(dp(142), self.texture_size[1] + dp(20))
                padding: dp(12), dp(10)

        # --- INFO VIDA ---
        Label:
            text: root.vida_info
            size_hint_y: None
            height: '26dp'
            font_size: '12sp'
            color: 0.55, 0.55, 0.7, 1
            halign: 'center'
            text_size: self.size
            valign: 'middle'

        # --- ZONA CENTRAL (scrollable) ---
        ScrollView:
            do_scroll_x: False

            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: '12dp', '6dp'
                spacing: '8dp'

                # ======== FASE: ADIVINAR ========
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(260) if root.fase == 'adivinar' else 0
                    opacity: 1 if root.fase == 'adivinar' else 0
                    spacing: '10dp'

                    # Libro
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '52dp'
                        spacing: '10dp'
                        Label:
                            text: "Libro"
                            size_hint_x: 0.22
                            font_size: '15sp'
                            bold: True
                            color: 0.85, 0.85, 0.85, 1
                            halign: 'left'
                            text_size: self.size
                            valign: 'middle'
                        Spinner:
                            id: spinner_libro_g
                            text: "Seleccionar libro..."
                            values: root.libros_nombres
                            size_hint_x: 0.78
                            font_size: '14sp'
                            background_normal: ''
                            background_color: 0.15, 0.15, 0.3, 1
                            color: 0.95, 0.95, 0.9, 1
                            on_text: root.on_libro_seleccionado(self.text)

                    # Capitulo
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '52dp'
                        spacing: '10dp'
                        Label:
                            text: "Capitulo"
                            size_hint_x: 0.22
                            font_size: '15sp'
                            bold: True
                            color: 0.85, 0.85, 0.85, 1
                            halign: 'left'
                            text_size: self.size
                            valign: 'middle'
                        Spinner:
                            id: spinner_capitulo_g
                            text: "Capitulo..."
                            values: root.capitulos_lista
                            size_hint_x: 0.78
                            font_size: '14sp'
                            disabled: not root.libro_ok
                            opacity: 0.4 if self.disabled else 1
                            background_normal: ''
                            background_color: 0.15, 0.15, 0.3, 1
                            color: 0.95, 0.95, 0.9, 1
                            on_text: root.on_capitulo_seleccionado(self.text)

                    # Versiculo
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '52dp'
                        spacing: '10dp'
                        Label:
                            text: "Versiculo"
                            size_hint_x: 0.22
                            font_size: '15sp'
                            bold: True
                            color: 0.85, 0.85, 0.85, 1
                            halign: 'left'
                            text_size: self.size
                            valign: 'middle'
                        Spinner:
                            id: spinner_versiculo_g
                            text: "Versiculo..."
                            values: root.versiculos_lista
                            size_hint_x: 0.78
                            font_size: '14sp'
                            disabled: not root.capitulo_ok
                            opacity: 0.4 if self.disabled else 1
                            background_normal: ''
                            background_color: 0.15, 0.15, 0.3, 1
                            color: 0.95, 0.95, 0.9, 1

                    # Botones: comprobar + saltar
                    BoxLayout:
                        orientation: 'horizontal'
                        size_hint_y: None
                        height: '56dp'
                        spacing: '8dp'

                        BotonEstilizado:
                            texto: "Comprobar"
                            mostrar_icono: False
                            size_hint_x: 0.65
                            color_fondo: (0.95, 0.85, 0.4, 1) if root.capitulo_ok else (0.18, 0.18, 0.18, 0.6)
                            on_release: root.comprobar() if root.capitulo_ok else None

                        BotonEstilizado:
                            texto: "Saltar"
                            mostrar_icono: False
                            size_hint_x: 0.35
                            color_fondo: (0.25, 0.25, 0.35, 1)
                            on_release: root.siguiente_verso()

                # ======== FASE: RESULTADO ========
                BoxLayout:
                    orientation: 'vertical'
                    size_hint_y: None
                    height: dp(290) if root.fase == 'resultado' else 0
                    opacity: 1 if root.fase == 'resultado' else 0
                    spacing: '10dp'
                    padding: 0, '4dp'

                    # Barra de puntuacion
                    Label:
                        text: f"Puntuacion:  {root.score_value:.1f}  / 1.0"
                        size_hint_y: None
                        height: '26dp'
                        font_size: '16sp'
                        bold: True
                        color: root.score_color
                        halign: 'center'
                        text_size: self.size
                        valign: 'middle'

                    Widget:
                        size_hint_y: None
                        height: '22dp'
                        canvas:
                            Color:
                                rgba: 0.18, 0.18, 0.25, 1
                            RoundedRectangle:
                                pos: self.pos
                                size: self.size
                                radius: [dp(11)]
                            Color:
                                rgba: root.score_color
                            RoundedRectangle:
                                pos: self.pos
                                size: self.width * root.score_value, self.height
                                radius: [dp(11)]

                    # Resultado libro
                    Label:
                        text: root.resultado_libro
                        size_hint_y: None
                        height: '44dp'
                        font_size: '14sp'
                        bold: True
                        color: root.resultado_color_libro
                        halign: 'left'
                        text_size: self.size
                        valign: 'middle'
                        padding: dp(8), 0

                    # Resultado capitulo
                    Label:
                        text: root.resultado_cap
                        size_hint_y: None
                        height: '44dp'
                        font_size: '14sp'
                        bold: True
                        color: root.resultado_color_cap
                        halign: 'left'
                        text_size: self.size
                        valign: 'middle'
                        padding: dp(8), 0

                    # Resultado versiculo
                    Label:
                        text: root.resultado_vers
                        size_hint_y: None
                        height: '44dp'
                        font_size: '14sp'
                        bold: True
                        color: root.resultado_color_vers
                        halign: 'left'
                        text_size: self.size
                        valign: 'middle'
                        padding: dp(8), 0

                    # Siguiente verso
                    BotonEstilizado:
                        texto: "Siguiente Versiculo"
                        mostrar_icono: False
                        size_hint_y: None
                        height: '56dp'
                        color_fondo: (0.95, 0.85, 0.4, 1)
                        on_release: root.siguiente_verso()

                # ======== FASE: SIN DATOS ========
                BoxLayout:
                    size_hint_y: None
                    height: dp(80) if root.fase == 'sin_datos' else 0
                    opacity: 1 if root.fase == 'sin_datos' else 0
                    Label:
                        text: root.verse_text
                        font_size: '15sp'
                        color: 0.7, 0.7, 0.8, 1
                        halign: 'center'
                        text_size: self.size
                        valign: 'middle'

        # --- BOTON VOLVER (siempre visible) ---
        BotonEstilizado:
            texto: "Volver a Lectura Biblica"
            mostrar_icono: False
            size_hint_y: None
            height: '56dp'
            color_fondo: (0.3, 0.3, 0.3, 0.6)
            on_release:
                app.root.transition.direction = 'right'
                app.root.current = 'verses'
