<ConfigScreen>:
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgb: 0.05, 0.05, 0.05
            Rectangle:
                size: self.size
                pos: self.pos

        # Encabezado
        Label:
            text: "Configuración y Datos"
            font_size: '24sp'
            bold: True
            size_hint_y: None
            height: '80dp'

        ScrollView:
            BoxLayout:
                orientation: 'vertical'
                padding: '20dp'
                spacing: '15dp'
                size_hint_y: None
                height: self.minimum_height

                # --- SECCIÓN PERFIL ---
                Label:
                    text: "Cuenta de Usuario"
                    halign: 'left'
                    text_size: self.width, None
                    color: 0.7, 0.7, 0.7, 1

                BotonEstilizado:
                    texto: "Reingresar Datos de Perfil"
                    size_hint_y: None
                    height: '60dp'
                    mostrar_icono: False
                    color_fondo: 0.2, 0.4, 0.8, 1
                    on_release: root.go_to_profile_edit()

                Widget:
                    size_hint_y: None
                    height: '20dp'

                # --- SECCIÓN BACKUP ---
                Label:
                    text: "Copia de Seguridad (Backup)"
                    halign: 'left'
                    text_size: self.width, None
                    color: 0.7, 0.7, 0.7, 1

                BotonEstilizado:
                    texto: "Exportar todo (.zip)"
                    size_hint_y: None
                    height: '60dp'
                    mostrar_icono: False
                    color_fondo: 0.1, 0.6, 0.3, 1
                    on_release: root.open_file_manager(mode='export')

                BotonEstilizado:
                    texto: "Importar desde archivo"
                    size_hint_y: None
                    height: '60dp'
                    mostrar_icono: False
                    color_fondo: 0.6, 0.4, 0.2, 1
                    on_release: root.open_file_manager(mode='import')

                # Información adicional
                Label:
                    text: "El Linaje v0.2.8\nLos datos se guardan de forma local."
                    halign: 'center'
                    font_size: '12sp'
                    color: 0.4, 0.4, 0.4, 1
                    size_hint_y: None
                    height: '100dp'

                BotonEstilizado:
                    texto: "Buscar Versículos"
                    size_hint_y: None
                    height: '60dp'
                    icono: "images/search_icon.png"
                    color_fondo: 0.6, 0.4, 0.2, 1
                    on_release: root.openbible()

        # Botón Volver
        BotonEstilizado:
            texto: "Volver al Menú Principal"
            size_hint_y: None
            height: '50dp'
            mostrar_icono: False
            color_fondo: 0.5, 0.1, 0.1, 1
            on_release:
                app.root.transition.direction = 'right'
                root.manager.current = 'main'
