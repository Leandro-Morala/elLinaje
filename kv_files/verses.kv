<VersesScreen>:
    BoxLayout:
        orientation: 'vertical'
        canvas.before:
            Color:
                rgba: 0.06, 0.06, 0.12, 1
            Rectangle:
                pos: self.pos
                size: self.size

        # --- TITULO ---
        BoxLayout:
            size_hint_y: None
            height: '50dp'
            canvas.before:
                Color:
                    rgba: 0.08, 0.08, 0.18, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 0.95, 0.78, 0.1, 0.7
                Line:
                    points: self.x, self.y, self.x + self.width, self.y
                    width: 1.5
            Label:
                text: "Lectura Biblica"
                font_size: '20sp'
                bold: True
                color: 0.95, 0.78, 0.1, 1

        # --- FORMULARIO (scrollable) ---
        ScrollView:
            do_scroll_x: False
            size_hint_y: 0.72

            BoxLayout:
                orientation: 'vertical'
                size_hint_y: None
                height: self.minimum_height
                padding: '14dp', '10dp'
                spacing: '12dp'

                # -- Libro --
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: '52dp'
                    spacing: '10dp'

                    Label:
                        text: "Libro"
                        size_hint_x: 0.22
                        font_size: '15sp'
                        bold: True
                        color: 0.85, 0.85, 0.85, 1
                        halign: 'left'
                        text_size: self.size
                        valign: 'middle'

                    Spinner:
                        id: spinner_libro
                        text: "Seleccionar libro..."
                        values: root.libros_nombres
                        size_hint_x: 0.78
                        font_size: '14sp'
                        background_normal: ''
                        background_color: 0.15, 0.15, 0.3, 1
                        color: 0.95, 0.95, 0.9, 1
                        on_text: root.on_libro_seleccionado(self.text)

                # -- Capitulo --
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: '52dp'
                    spacing: '10dp'

                    Label:
                        text: "Capitulo"
                        size_hint_x: 0.22
                        font_size: '15sp'
                        bold: True
                        color: 0.85, 0.85, 0.85, 1
                        halign: 'left'
                        text_size: self.size
                        valign: 'middle'

                    Spinner:
                        id: spinner_capitulo
                        text: "Capitulo..."
                        values: root.capitulos_lista
                        size_hint_x: 0.78
                        font_size: '14sp'
                        disabled: not root.libro_ok
                        opacity: 0.4 if self.disabled else 1
                        background_normal: ''
                        background_color: 0.15, 0.15, 0.3, 1
                        color: 0.95, 0.95, 0.9, 1
                        on_text: root.on_capitulo_seleccionado(self.text)

                # -- Versiculo --
                BoxLayout:
                    orientation: 'horizontal'
                    size_hint_y: None
                    height: '52dp'
                    spacing: '10dp'

                    Label:
                        text: "Versiculo"
                        size_hint_x: 0.22
                        font_size: '15sp'
                        bold: True
                        color: 0.85, 0.85, 0.85, 1
                        halign: 'left'
                        text_size: self.size
                        valign: 'middle'

                    Spinner:
                        id: spinner_versiculo
                        text: "Versiculo..."
                        values: root.versiculos_lista
                        size_hint_x: 0.78
                        font_size: '14sp'
                        disabled: not root.capitulo_ok
                        opacity: 0.4 if self.disabled else 1
                        background_normal: ''
                        background_color: 0.15, 0.15, 0.3, 1
                        color: 0.95, 0.95, 0.9, 1
                        on_text: root.on_versiculo_seleccionado(self.text)

                # -- Texto del versiculo --
                TextInput:
                    id: text_input
                    hint_text: "Escribe el versiculo de memoria..."
                    disabled: not root.versiculo_ok
                    opacity: 0.4 if self.disabled else 1
                    multiline: True
                    size_hint_y: None
                    height: '130dp'
                    background_color: 0.1, 0.1, 0.22, 1
                    foreground_color: 0.95, 0.95, 0.88, 1
                    hint_text_color: 0.4, 0.4, 0.55, 1
                    cursor_color: 0.95, 0.78, 0.1, 1
                    font_size: '16sp'
                    padding: '10dp', '10dp'

                # -- Estado --
                Label:
                    text: root.status_text
                    size_hint_y: None
                    height: '28dp'
                    font_size: '13sp'
                    halign: 'center'
                    text_size: self.size
                    valign: 'middle'
                    color: 0.95, 0.78, 0.1, 1

                # -- Boton guardar --
                BotonEstilizado:
                    texto: "Guardar Versiculo"
                    mostrar_icono: False
                    size_hint_y: None
                    height: '56dp'
                    color_fondo: (0.2, 0.55, 0.25, 1) if root.versiculo_ok else (0.18, 0.18, 0.18, 0.6)
                    on_release: root.guardar_versiculo()

        # --- AREA INFERIOR ---
        BoxLayout:
            orientation: 'vertical'
            size_hint_y: 0.28
            padding: '10dp', '6dp'
            spacing: '8dp'
            canvas.before:
                Color:
                    rgba: 0.07, 0.07, 0.14, 1
                Rectangle:
                    pos: self.pos
                    size: self.size
                Color:
                    rgba: 0.95, 0.78, 0.1, 0.25
                Line:
                    points: self.x, self.top, self.x + self.width, self.top
                    width: 1

            Label:
                text: root.verse_count
                size_hint_y: None
                height: '26dp'
                font_size: '14sp'
                bold: True
                color: 0.7, 0.7, 0.82, 1
                halign: 'center'
                text_size: self.size
                valign: 'middle'

            BotonEstilizado:
                texto: "Iniciar Partida"
                mostrar_icono: False
                color_fondo: (0.95, 0.85, 0.4, 1)
                on_release: root.ir_a_partida()

            BotonEstilizado:
                texto: "Volver al Principal"
                mostrar_icono: False
                color_fondo: (0.3, 0.3, 0.3, 0.6)
                on_release:
                    app.root.transition.direction = 'right'
                    app.root.current = 'main'
